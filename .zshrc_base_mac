# .zshrc — Mac platform config

# Brew shellenv (must be before oh-my-zsh so plugins like keychain find brew binaries)
eval "$(/opt/homebrew/bin/brew shellenv)"

# Mac-specific path specs
export PATH=${PATH}:/usr/local/lib
export PATH=${PATH}:/opt/homebrew/lib
export PATH=${PATH}:~/bin
export GEM_HOME="$HOME/.gem"

# Platform-specific plugins
PLATFORM_PLUGINS=(bundler gpg-agent keychain brew)

# config for keychain (must be set before oh-my-zsh sources the plugin)
zstyle :omz:plugins:keychain agents gpg,ssh
zstyle :omz:plugins:keychain identities id_ed25519 hwagyesa-github google_compute_engine raspi

# Source common config
source "${0:a:h}/.zshrc_base_common"

# Bash completion (used for hydra completion) (TODO: doesn't work)
autoload -Uz bashcompinit && bashcompinit

# TODO: bugged in zsh
function gif2mp4() {
  local first_arg=$1 \
        second_arg=$2

  shift 2

  magick "$first_arg" -layers coalesce "$second_arg" "$@"

}

# Lua spec
# This is for a homebrew install as of 8/18/2022...
# TODO: not sure what uses this
export LUA_PREFIX="/opt/homebrew/Cellar/lua/5.4.4_1"

# Mypy path for stubs
export MYPYPATH=~/.vim/vim-lsp-settings/stubs

# Start keychain
# can do this with oh-my-zsh plugin
# eval `keychain --eval --agents ssh --inherit any id_ed25519`

# colors
export CLICOLOR=1

# for image.nvim luarocks
export DYLD_FALLBACK_LIBRARY_PATH="$(brew --prefix)/lib:$DYLD_FALLBACK_LIBRARY_PATH"

# Gstreamer setup...
export GST_PLUGIN_PATH="/opt/homebrew/lib/gstreamer-1.0"
export LIBGS="/opt/homebrew/Cellar/ghostscript/10.01.2/lib/libgs.dylib"



# config for ruby
eval "$(rbenv init - zsh)"
